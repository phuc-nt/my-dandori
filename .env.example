# my-dandori — env template. Copy to .env and fill real values (.env is gitignored).
# See docs/integration-setup.md for where each credential comes from.

# --- LLM provider (OpenRouter) ---
OPENROUTER_API_KEY=          # sk-or-...
OPENROUTER_MODEL=minimax/minimax-m2.7
OPENROUTER_REFERER=https://github.com/local/my-dandori
OPENROUTER_TITLE=my-dandori

# --- Atlassian (Jira + Confluence: one shared site + token) ---
ATLASSIAN_SITE_NAME=         # <org>.atlassian.net
ATLASSIAN_USER_EMAIL=        # you@example.com
ATLASSIAN_API_TOKEN=         # ATATT... (id.atlassian.com -> API tokens)

# --- Slack (browser-token) ---
SLACK_XOXC_TOKEN=            # xoxc-...
SLACK_XOXD_TOKEN=            # xoxd-... (URL-encoded)
SLACK_TEAM_DOMAIN=           # workspace subdomain

# --- Test-tenant fixtures ---
JIRA_PROJECT_KEY=
GITHUB_REPO=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_SPACE_ID=
OKR_CONFLUENCE_PAGE_ID=
SLACK_REPORT_CHANNEL=
SLACK_STAKEHOLDER_CHANNEL=
SLACK_EXTERNAL_CHANNELS=

# --- Google Workspace: NO token here — gws CLI OAuth (~/.config/gws/). Just have gws on PATH. ---
# HR_SHEET_ID= / HR_SHEET_RANGE= set per-run when reading a Sheet.

# --- Guardrails ---
DRY_RUN=true
AGENT_WRITE_DISABLED=false
MONTHLY_BUDGET_USD=50
BUDGET_WARN_RATIO=0.8

# --- Notifications (v8) ---
# PUBLIC_BASE_URL: console origin for deep links in Slack alerts (default: http://<listen>).
# NOTIFY_FLAG_STALE_DAYS: announce an open flag once it is older than this (default 3).
PUBLIC_BASE_URL=
NOTIFY_FLAG_STALE_DAYS=3
